\NeedsTeXFormat{LaTeX2e}[2020/10/01]
\ProvidesPackage{exonot}[2026/06/27 v0.1.0 <short description of the package>]

%% ---------------------------------------------------------------------------
%% Required packages
%% ---------------------------------------------------------------------------
\RequirePackage{xcolor}
\RequirePackage{kvoptions}

%% ---------------------------------------------------------------------------
%% Package options
%% ---------------------------------------------------------------------------
\SetupKeyvalOptions{
  family=exonot,
  prefix=exonot@,
}

% Example boolean option:  \usepackage[draft]{exonot}
\DeclareBoolOption{draft}
% Example string option:   \usepackage[color=blue]{exonot}
\DeclareStringOption[black]{color}

\ProcessKeyvalOptions{exonot}

%% ---------------------------------------------------------------------------
%% Internal helpers
%% ---------------------------------------------------------------------------
\newcommand{\exonot@warn}[1]{\PackageWarning{exonot}{#1}}

%% ---------------------------------------------------------------------------
%% Public macros
%% ---------------------------------------------------------------------------
% \hello -- a minimal demonstration command; replace with real macros.
\newcommand{\hello}[1][world]{%
  \textcolor{\exonot@color}{Hello, #1!}%
  \ifexonot@draft\space\textbf{[draft]}\fi
}

\endinput
